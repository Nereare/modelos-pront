<!DOCTYPE html>
<html>
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1">
		<meta name="apple-mobile-web-app-title" content="Bossy">

		<title>{{ app_name | default('Modelos de Prontuários v3') }}</title>

    <link rel="icon" type="image/png" href="{{ asset('favicon/favicon-96x96.png' )}}" sizes="96x96"/>
    <link rel="icon" type="image/svg+xml" href="{{ asset('favicon/favicon.svg' )}}"/>
    <link rel="shortcut icon" href="{{ asset('favicon/favicon.ico' )}}"/>
    <link rel="apple-touch-icon" sizes="180x180" href="{{ asset('favicon/apple-touch-icon.png' )}}"/>
    <meta name="apple-mobile-web-app-title" content="Pront"/>
    <link rel="manifest" href="{{ asset('favicon/site.webmanifest' )}}"/>

		{% block stylesheets %}{% endblock %}
    {{ encore_entry_link_tags('pront') }}

		{% block javascripts %}{% endblock %}
    {{ encore_entry_script_tags('pront') }}
    {% block importmap %}{{ importmap('app') }}{% endblock %}
	</head>
	<body>
		{% block body %}{% endblock %}
	</body>
</html>
