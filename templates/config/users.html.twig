{% extends 'config/base.html.twig' %}

{% block content %}
<section class="section">
  <div class="container">
    <div class="box">
      <h2 class="title is-3">
        <span class="icon-text">
          <span class="icon">
            <i class="mdi mdi-hospital-building"></i>
          </span>
          <span>Locais de Atendimento</span>
      </h2>

      {% set places = app.user.getPlaces %}

      <table class="table is-striped is-hoverable is-fullwidth">
        <thead>
          <tr>
            <td>Nome</td>
            <td>CNES</td>
            <td>Ações</td>
          </tr>
        </thead>
        <tbody>
        {% if places|length %}
        {% for place in places %}
          <tr>
            <td>{{ place.getName }}</td>
            <td>{{ place.getCnes }}</td>
            <td>
              <div class="field has-addons">
                <div class="control">
                  <a class="button is-small" title="Editar" href="{{ path('config_place_edit', { 'place': place.getId }) }}">
                    <span class="icon">
                      <i class="mdi mdi-pencil"></i>
                    </span>
                  </a>
                </div>
                <div class="control">
                {% if place.getId == app.user.place.getId %}
                  <button class="button is-small" title="Atual" disabled>
                    <span class="icon">
                      <i class="mdi mdi-map-marker-radius"></i>
                    </span>
                  </button>
                {% else %}
                  <button class="button is-small select-place" title="Selecionar" target="{{ path('config_place_select', { 'place': place.getId }) }}">
                    <span class="icon">
                      <i class="mdi mdi-map-marker-check"></i>
                    </span>
                  </button>
                {% endif %}
                </div>
                <div class="control">
                  <button class="button is-small is-danger delete-place" title="Deletar" target="{{ path('config_place_remove', { 'place': place.getId }) }}">
                    <span class="icon">
                      <i class="mdi mdi-delete"></i>
                    </span>
                  </button>
                </div>
              </div>
            </td>
          </tr>
        {% endfor %}
        {% else %}
          <tr>
            <td colspan="3" class="has-text-centered">Nenhum local de atendimento cadastrado.</td>
          </tr>
        {% endif %}
        </tbody>
      </table>

      <div class="field">
        <div class="control is-expanded">
          <a class="button is-success is-fullwidth" href="{{ path('config_place_new') }}">
            <span class="icon-text">
              <span class="icon">
                <i class="mdi mdi-plus"></i>
              </span>
              <span>Criar Local de Atendimento</span>
            </span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
{% endblock %}
