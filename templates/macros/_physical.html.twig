								<option value="grau 2 de Brodsky">Grau 2</option>
								<option value="grau 3 de Brodsky">Grau 3</option>
								<option value="grau 4 de Brodsky">Grau 4</option>
							</select>
						</div>
					</div>
				</div>

        <div class="field has-addons">
					<div class="control">
						<button class="button is-static" tabindex="-1">Cobert. Tonsilas</button>
					</div>
					<div class="control is-expanded">
						<div class="select is-fullwidth">
							<select id="oro-d-tonsils-cover">
                <option value="" selected>Dir (N/A)</option>
								<option value="sem placas, cáseos, ou outras coberturas">Normal</option>
                <option value="com trama fibrínica">Fibrina</option>
								<option value="com cáseos">Cáseos</option>
								<option value="com placas purulentas">Pus</option>
							</select>
						</div>
					</div>
					<div class="control is-expanded">
						<div class="select is-fullwidth">
							<select id="oro-e-tonsils-cover">
                <option value="" selected>Esq (N/A)</option>
								<option value="sem placas, cáseos, ou outras coberturas">Normal</option>
                <option value="com trama fibrínica">Fibrina</option>
								<option value="com cáseos">Cáseos</option>
								<option value="com placas purulentas">Pus</option>
							</select>
						</div>
					</div>
        </div>

				<div class="field has-addons">
					<div class="control">
						<button class="button is-static" tabindex="-1">Palato</button>
					</div>
					<div class="control is-expanded">
						<div class="select is-fullwidth">
							<select id="oro-palate">
                <option value="" selected>N/A</option>
								<option value="centralizado, sem desvios">Normal</option>
								<option value="com desvio à direita">Desvio D</option>
								<option value="com desvio à esquerda">Desvio E</option>
								<option value="sem úvula visível">&empty;Úvula</option>
							</select>
						</div>
					</div>
				</div>

				<div class="field has-addons">
					<div class="control">
						<button class="button is-static" tabindex="-1">Higiene</button>
					</div>
					<div class="control is-expanded">
						<div class="select is-fullwidth">
							<select id="oro-hygine">
                <option value="" selected>N/A</option>
								<option value="Bom estado de higiene oral">Boa</option>
								<option value="Mal estado de higiene oral">&half;Ruim</option>
								<option value="Péssimo estado de higiene oral">&uarr;Ruim</option>
