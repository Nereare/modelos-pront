{##
  A gender selection select field.
#}
{% macro gender() %}
<div class="box">
  <div class="field has-addons">
    <div class="control">
      <button class="button is-static" tabindex="-1">Declinação de Gênero</button>
    </div>
    <div class="control is-expanded">
      <div class="select is-fullwidth">
        <select id="pronouns" title="Qual declinação de gênero e/ou pronome será usado para descrever o exame físico, quando aplicável">
          <option value="e" selected>Neutro</option>
          <option value="o">Ele/Dele</option>
          <option value="a">Ela/Dela</option>
        </select>
      </div>
    </div>
  </div>
</div>
{% endmacro %}

{##
  The main physical exam fields: general, vital
  signs, and conscience.
#}
{% macro general() %}
<div class="box">
  <h2 class="title is-4">Estado Geral</h2>

  <div class="columns">
    <div class="column">
      <div class="field">
        <div class="control is-expanded">
          <div class="select is-fullwidth">
            <select id="status" title="Estado geral">
              <option value="Bom" selected>BEG</option>
              <option value="Regular">REG</option>
              <option value="Mal">MEG</option>
            </select>
          </div>
        </div>
      </div>
    </div>

    <div class="column">
      <div class="field">
        <div class="control is-expanded">
          <div class="select is-fullwidth">
            <select id="nutrition" title="Estado nutricional">
              <option value="" selected>Status Nutric. (N/A)</option>
              <option value="Eutrófic((PRO))">Eutrófice</option>
              <option value="Esmaecid((PRO))">Esmaecide</option>
              <option value="Caquétic((PRO))">Caquétice</option>
            </select>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="field">
    <label class="is-checkradio">
      <input class="is-success" type="radio" name="color" value="Corad((PRO))" checked>
      <span>Corade</span>
    </label>
    <label class="is-checkradio">
      <input class="is-warning" type="radio" name="color" value="1">
      <span>&plus;</span>
    </label>
    <label class="is-checkradio">
      <input class="is-danger" type="radio" name="color" value="2">
      <span>&plus;&plus;</span>
    </label>
    <label class="is-checkradio">
      <input class="is-danger" type="radio" name="color" value="3">
      <span>&plus;&plus;&plus;</span>
    </label>
    <label class="is-checkradio">
      <input class="is-danger" type="radio" name="color" value="4">
      <span>&plus;&plus;&plus;&plus;</span>
    </label>
  </div>

  <div class="field">
    <label class="is-checkradio">
      <input class="is-success" type="radio" name="hydro" value="hidratad((PRO))" checked>
      <span>Hidratade</span>
    </label>
    <label class="is-checkradio">
      <input class="is-warning" type="radio" name="hydro" value="1">
      <span>&plus;</span>
    </label>
    <label class="is-checkradio">
      <input class="is-danger" type="radio" name="hydro" value="2">
      <span>&plus;&plus;</span>
    </label>
    <label class="is-checkradio">
      <input class="is-danger" type="radio" name="hydro" value="3">
      <span>&plus;&plus;&plus;</span>
    </label>
    <label class="is-checkradio">
      <input class="is-danger" type="radio" name="hydro" value="4">
      <span>&plus;&plus;&plus;&plus;</span>
    </label>
  </div>

  <div class="field">
    <label class="is-checkradio">
      <input class="is-success" type="radio" name="cyanose" value="acianótic((PRO))" checked>
      <span>Acianótice</span>
    </label>
    <label class="is-checkradio">
      <input class="is-warning" type="radio" name="cyanose" value="1">
      <span>&plus;</span>
    </label>
    <label class="is-checkradio">
      <input class="is-danger" type="radio" name="cyanose" value="2">
      <span>&plus;&plus;</span>
    </label>
    <label class="is-checkradio">
      <input class="is-danger" type="radio" name="cyanose" value="3">
      <span>&plus;&plus;&plus;</span>
    </label>
    <label class="is-checkradio">
      <input class="is-danger" type="radio" name="cyanose" value="4">
      <span>&plus;&plus;&plus;&plus;</span>
    </label>
  </div>

  <div class="field">
    <label class="is-checkradio">
      <input class="is-success" type="radio" name="icter" value="anictéric((PRO))" checked>
      <span>Anictérice</span>
    </label>
    <label class="is-checkradio">
      <input class="is-warning" type="radio" name="icter" value="1">
      <span>&plus;</span>
    </label>
    <label class="is-checkradio">
      <input class="is-danger" type="radio" name="icter" value="2">
      <span>&plus;&plus;</span>
    </label>
    <label class="is-checkradio">
      <input class="is-danger" type="radio" name="icter" value="3">
      <span>&plus;&plus;&plus;</span>
    </label>
    <label class="is-checkradio">
      <input class="is-danger" type="radio" name="icter" value="4">
      <span>&plus;&plus;&plus;&plus;</span>
    </label>
  </div>

  <div class="field">
    <label class="is-checkradio">
      <input class="is-link" type="radio" name="fever" value="" checked>
      <span>NT</span>
    </label>
    <label class="is-checkradio">
      <input class="is-success" type="radio" name="fever" value="afebril">
      <span>Afebril</span>
    </label>
    <label class="is-checkradio">
      <input class="is-danger" type="radio" name="fever" value="febril">
      <span>Febril</span>
    </label>
    <label class="is-checkradio">
      <input class="is-danger" type="radio" name="fever" value="hipotérmic((PRO))">
      <span>Hipotérmice</span>
    </label>
  </div>

  <div class="field has-addons">
    <div class="control">
      <button class="button is-static" tabindex="-1">Estado Respiratório</button>
    </div>
    <div class="control">
      <div class="select">
        <select id="breathing">
          <option value="">N/A</option>
          <option value="eupneic((PRO))" selected>Eupneice</option>
          <option value="eupneic((PRO)) (ausência de quaisquer sinais objetivos de dispneia - sem de uso de musculaturas respiratórias acessórias, sem postura compensatória)">Eupneice (enfático)</option>
          <option value="taquipneic((PRO))">Taquipneice</option>
          <option value="bradipneic((PRO))">Bradipneice</option>
          <option value="taquidispneic((PRO))">Taquidispneice</option>
          <option value="bradidispneic((PRO))">Bradidispneice</option>
          <option value="other">Outro...</option>
        </select>
      </div>
    </div>
    <div class="control is-expanded">
      <input class="input" id="breathing-other" placeholder="Descreva..." disabled>
    </div>
  </div>

  <div class="field has-addons">
    <div class="control">
      <button class="button is-static" tabindex="-1">Fácies</button>
    </div>
    <div class="control">
      <div class="select">
        <select id="face">
          <optgroup label="Gerais">
            <option value="atípica" selected>Normal</option>
            <option value="other">Outra...</option>
          </optgroup>
          <optgroup label="Sindrômicas">
            <option value="acromegálica">Acromegálica</option>
            <option value="adenoidiana">Adenoidiana</option>
            <option value="cushingoide (ou 'moonface')">Cushingoide</option>
            <option value="esclerodérmica">Esclerodérmica</option>
            <option value="leonina">Leonina</option>
            <option value="miastênica (ou de Hutchinson)">Miastênica</option>
            <option value="parkinsoniana">Parkinsoniana</option>
            <option value="renal">Renal</option>
            <option value="tireotóxica (ou basedowiana)">Tireotóxica</option>
          </optgroup>
          <optgroup label="Sintomáticas">
            <option value="dolorosa">Dolorosa</option>
            <option value="sonolenta">Sonolenta</option>
            <option value="entristecida">Entristecida</option>
            <option value="astênica">Astênica</option>
            <option value="persecutória">Persecutória</option>
          </optgroup>
        </select>
      </div>
    </div>
    <div class="control is-expanded">
      <input type="text" class="input" id="face-other" placeholder="Descreva..." disabled>
    </div>
  </div>
</div>

<div class="box">
	<h2 class="title is-4">Sinais Vitais</h2>

	<div class="columns">
		<div class="column">
			<div class="field has-addons">
				<div class="control">
					<button class="button is-static" tabindex="-1">Sat</button>
				</div>
				<div class="control is-expanded">
					<input type="number" id="ssvv-sat" class="input" min="0" max="100" step="1" placeholder="#">
				</div>
				<div class="control">
					<button class="button is-static" tabindex="-1">%</button>
				</div>
				<div class="control">
					<div class="select">
						<select id="ssvv-sat-type" title="Tipo de aporte de oxigênio: 'aa' = ar ambiente / 'CN' = cateter nasal de oxigênio / 'CAF' = cateter nasal de alto fluxo / 'MNR' = máscara não reinalante">
							<option value="ar ambiente" selected>aa</option>
							<option value="cateter nasal de O2">CN</option>
              <option value="cateter nasal de alto fluxo">CAF</option>
							<option value="máscara não-reinalante">MNR</option>
						</select>
					</div>
				</div>
				<div class="control is-expanded">
					<input type="number" id="ssvv-sat-flux" class="input" min="0" max="15" step="1" placeholder="#" title="Fluxo de oxigênio" disabled>
				</div>
				<div class="control">
					<button class="button is-static" tabindex="-1">L/min</button>
				</div>
			</div>

			<div class="field has-addons">
				<div class="control">
					<button class="button is-static" tabindex="-1">Pulso</button>
				</div>
				<div class="control is-expanded">
					<input type="number" id="ssvv-pulse" class="input" min="1" step="1" placeholder="#">
				</div>
				<div class="control">
					<button class="button is-static" tabindex="-1">bpm</button>
				</div>
			</div>

			<div class="field has-addons">
				<div class="control">
					<button class="button is-static" tabindex="-1">PA</button>
				</div>
				<div class="control is-expanded">
					<input type="number" id="ssvv-pas" class="input" min="1" step="2" placeholder="PAS" title="Pressão arterial sistólica em milímetros de mercúrio">
				</div>
				<div class="control">
					<button class="button is-static" tabindex="-1">/</button>
				</div>
				<div class="control is-expanded">
					<input type="number" id="ssvv-pad" class="input" min="1" step="2" placeholder="PAD" title="Pressão arterial diastólica em milímetros de mercúrio">
				</div>
				<div class="control">
					<button class="button is-static" tabindex="-1">mmHg</button>
				</div>
			</div>

			<div class="field has-addons">
				<div class="control">
					<button class="button is-static" tabindex="-1">FR</button>
				</div>
				<div class="control is-expanded">
					<input type="number" id="ssvv-fr" class="input" min="1" step="1" placeholder="#" title="# incursões respiratórias por minuto">
				</div>
				<div class="control">
					<button class="button is-static" tabindex="-1">irpm</button>
				</div>
			</div>

			<div class="field has-addons">
				<div class="control">
					<button class="button is-static" tabindex="-1">Dextro</button>
				</div>
				<div class="control">
					<input type="number" id="ssvv-glucose" class="input" min="1" step="1" placeholder="# (HI > 400)">
				</div>
				<div class="control">
					<button class="button is-static" tabindex="-1">mg/dL</button>
				</div>
				<div class="control is-expanded">
					<div class="select is-fullwidth">
						<select id="ssvv-glucose-time">
							<option value="" selected>Desconhecida</option>
							<option value=" (jejum)">Jejum</option>
							<option value=" (pós-alimentação)">PÓS-Aliment</option>
						</select>
					</div>
				</div>
			</div>
		</div>

		<div class="column">
			<div class="field has-addons">
				<div class="control">
					<button class="button is-static" tabindex="-1">Temp</button>
				</div>
				<div class="control is-expanded">
					<input type="number" id="ssvv-temp" class="input" min="1" step="0.1" placeholder="#">
				</div>
				<div class="control">
					<button class="button is-static" tabindex="-1">°C</button>
				</div>
				<div class="control">
					<div class="select">
						<select id="ssvv-temp-desc">
							<option value="infravermelho de testa" selected>testa</option>
							<option value="axilar">axila</option>
						</select>
					</div>
				</div>
			</div>

			<div class="field has-addons">
				<div class="control">
					<button class="button is-static" tabindex="-1">Peso</button>
				</div>
				<div class="control">
					<div class="select">
						<select id="ssvv-weight-eq">
							<option value="~" title="Peso APROXIMADO" selected>~</option>
							<option value="= " title="Peso exato aferido neste contato">=</option>
						</select>
					</div>
				</div>
				<div class="control is-expanded">
					<input type="number" id="ssvv-weight" class="input" min="0" step="0.1" placeholder="#">
				</div>
				<div class="control">
					<button class="button is-static" tabindex="-1">kg</button>
				</div>
			</div>

			<div class="field has-addons">
				<div class="control">
					<button class="button is-static" tabindex="-1">Alt</button>
				</div>
				<div class="control is-expanded">
					<input type="number" id="ssvv-height" class="input" min="1" step="1" placeholder="#">
				</div>
				<div class="control">
					<button class="button is-static" tabindex="-1">cm</button>
				</div>
			</div>

			<div class="field has-addons">
				<div class="control">
					<button class="button is-static" tabindex="-1">IMC</button>
				</div>
				<div class="control is-expanded">
					<input type="number" id="ssvv-bmi" class="input" placeholder="#" readonly>
				</div>
				<div class="control">
					<button class="button is-static" tabindex="-1">kg/m<sup>2</sup>
					</button>
				</div>
			</div>

			<div class="field has-addons">
				<div class="control">
					<button class="button is-static" tabindex="-1">Dor (EVA)</button>
				</div>
				<div class="control is-expanded">
					<div class="select is-fullwidth">
						<select id="ssvv-pain">
							<option value="" selected>N/A</option>
							<option value="0">&empty;</option>
							<option value="1">1</option>
							<option value="2">2</option>
							<option value="3">3</option>
							<option value="4">4</option>
							<option value="5">5</option>
							<option value="6">6</option>
							<option value="7">7</option>
							<option value="8">8</option>
							<option value="9">9</option>
							<option value="10">10</option>
						</select>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

<div class="box">
	<h2 class="title is-4">Consciência</h2>

	<div class="field has-addons">
		<div class="control">
			<button type="button" class="button is-static" tabindex="-1">GCS</button>
		</div>
		<div class="control">
			<button type="button" class="button is-static" tabindex="-1">AO</button>
		</div>
		<div class="control is-expanded">
			<div class="select is-fullwidth">
				<select id="ssvv-gcs-eye">
					<option value="" selected>N/A</option>
					<option value="4" title="Abre os olhos espontaneamente">4</option>
          <option value="3" title="Abre os olhos em resposta a um chamado">3</option>
          <option value="2" title="Abre os olhos em resposta a estímulo de dor">2</option>
          <option value="1" title="Não abre os olhos">1</option>
          <option value="0" title="Não testado">0 NT</option>
				</select>
			</div>
		</div>
		<div class="control">
			<button type="button" class="button is-static" tabindex="-1">RV</button>
		</div>
		<div class="control is-expanded">
			<div class="select is-fullwidth">
				<select id="ssvv-gcs-speech">
					<option value="" selected>N/A</option>
          <option value="5" title="Orientado, conversa normalmente">5</option>
          <option value="4" title="Confuso, desorientado">4</option>
          <option value="3" title="Pronuncia palavras desconexas">3</option>
          <option value="2" title="Emite sons incompreensíveis">2</option>
          <option value="1" title="Emudecido">1</option>
          <option value="0" title="Não testado">0 NT</option>
				</select>
			</div>
		</div>
		<div class="control">
			<button type="button" class="button is-static" tabindex="-1">RM</button>
		</div>
		<div class="control is-expanded">
			<div class="select is-fullwidth">
				<select id="ssvv-gcs-muscle">
					<option value="" selected>N/A</option>
					<option value="6" title="Obedece a comandos">6</option>
          <option value="5" title="Localiza estímulos dolorosos">5</option>
          <option value="4" title="Flexão inespecífica (normal)/ Reflexo de retirada a estímulos dolorosos">4</option>
          <option value="3" title="Flexão anormal a estímulos dolorosos (decorticação)">3</option>
          <option value="2" title="Extensão a estímulos dolorosos (descerebração)">2</option>
          <option value="1" title="Não se movimenta">1</option>
          <option value="0" title="Não testado">0 NT</option>
				</select>
			</div>
		</div>
	</div>

  <div class="field has-addons">
		<div class="control">
			<button type="button" class="button is-static" tabindex="-1">RASS</button>
		</div>
		<div class="control is-expanded">
			<div class="select is-fullwidth">
				<select id="ssvv-rass">
					<option value="" selected>N/A</option>
					<option value="+4" title="+4 - Violento, perigoso">Agressivo</option>
          <option value="+3" title="+3 - Conduta agressiva, remoção de tubos e catéteres">Muito agitado</option>
          <option value="+2" title="+2 - Movimentos sem coordenação frequente">Agitado</option>
          <option value="+1" title="+1 - Ansioso, mas sem movimentos agressivos ou vigorosos">Inquieto</option>
          <option value="0" title="0 - Consciência normal">Alerta, calmo</option>
          <option value="-1" title="-1 - Não se encontra totalmente alerta, mas tem o despertar sustentado ao som da voz por >10s">Sonolento</option>
          <option value="-2" title="-2 - Acorda rapidamente e faz contato visual com o som da voz, mas por <10s">Sedação leve</option>
          <option value="-3" title="-3 - Movimento ou abertura dos olhos ao som da voz, mas sem contato visual">Sedação moderada</option>
          <option value="-4" title="-4 - Não responde ao som da voz, mas movimenta ou abre os olhos com estimulação física">Sedação profunda</option>
          <option value="-5" title="-5 - Não responde ao som da voz ou ao estímulo físico">Incapaz de ser despertado</option>
				</select>
			</div>
		</div>
	</div>

	<div class="field has-addons">
		<div class="control">
			<button class="button is-static" tabindex="-1">Orientação Tempo-Espacial</button>
		</div>
		<div class="control is-expanded">
			<div class="select is-fullwidth">
				<select id="ssvv-orientation-time">
					<option value="" selected>Tempo</option>
					<option value="Orientad((PRO))">Orientade</option>
					<option value="DESorientad((PRO))">DESorientade</option>
				</select>
			</div>
		</div>
		<div class="control is-expanded">
			<div class="select is-fullwidth">
				<select id="ssvv-orientation-space">
					<option value="" selected>Espaço</option>
					<option value="Orientad((PRO))">Orientade</option>
					<option value="DESorientad((PRO))">DESorientade</option>
				</select>
			</div>
		</div>
	</div>

	<div class="field has-addons">
		<div class="control">
			<button class="button is-static" tabindex="-1">Colaboração</button>
		</div>
		<div class="control">
			<div class="select">
				<select id="ssvv-collaboration">
					<option value="" selected>N/A</option>
					<option value="Colaborativ((PRO))">Colaborative</option>
					<option value="Pouco colaborativ((PRO))">&darr;Colaborative</option>
					<option value="Agressiv((PRO))">Agressive</option>
					<option value="Hipoativ((PRO)) | Hiporreativ((PRO))">Hipo- Ative/Reative</option>
					<option value="Catatonic((PRO))">Catatonice</option>
					<option value="Evasiv((PRO))">Evasive</option>
					<option value="Hipomania">Hipomania</option>
					<option value="Mania">Mania</option>
          <option value="other">Outro...</option>
				</select>
			</div>
		</div>
    <div class="control is-expanded">
      <input class="input" id="ssvv-collaboration-other" placeholder="Descreva..." disabled>
    </div>
	</div>

	<div class="field has-addons">
		<div class="control">
			<button class="button is-static" tabindex="-1">Deambulação</button>
		</div>
		<div class="control">
			<div class="select">
				<select id="ssvv-walking">
					<option value="" selected>N/A</option>
					<option value="Deambulando sem apoios, sem claudicações e sem dificuldades">&empty;Apoios/Claud/Dificuldades</option>
					<option value="Deambulando sem apoios">&empty;Apoios</option>
					<option value="Em cadeirda de rodas">Cadeira Rodas</option>
					<option value="Em maca">Maca</option>
					<option value="other">Outro...</option>
				</select>
			</div>
		</div>
		<div class="control is-expanded">
			<input type="text" class="input" id="ssvv-walking-other" placeholder="Descreva..." disabled>
		</div>
	</div>
</div>
{% endmacro %}

{##
  Head physical exam fields.
#}
{% macro head() %}
<div class="box">
  <div class="field">
    <label class="is-checkradio">
      <input type="checkbox" class="is-primary collapsable" id="c-head" data-target="collapsable-head">
      <span class="icon-text">
        <span class="icon is-medium">
          <i class="mdi mdi-head mdi-36px"></i>
        </span>
        <span><strong>Cabeça</strong></span>
      </span>
    </label>
  </div>

  <div class="is-hidden" id="collapsable-head">
