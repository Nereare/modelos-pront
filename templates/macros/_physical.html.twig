		<div class="columns is-vcentered">
			<div class="column is-2">
				<div class="field">
					<label class="is-checkradio">
            <input type="checkbox" id="exam-nose" class="is-link">
						<span class="icon">
							<i class="mdi mdi-face-woman-profile mdi-24px"></i>
						</span>
					</label>
				</div>
			</div>

			<div class="column">
				<div class="field has-addons">
					<div class="control">
						<button class="button is-static" tabindex="-1">Mucosa</button>
					</div>
					<div class="control is-expanded">
						<div class="select is-fullwidth">
							<select id="nose-mucosa">
                <option value="" selected>N/A</option>
								<option value="de aspecto normal">Normal</option>
								<option value="levemente enantematosa">&half;Hiperem</option>
								<option value="bastante enantematosa">&uarr;Hiperem</option>
							</select>
						</div>
					</div>
				</div>

				<div class="field has-addons">
					<div class="control">
						<button class="button is-static" tabindex="-1">Cornetos</button>
					</div>
					<div class="control is-expanded">
						<div class="select is-fullwidth">
							<select id="nose-d-shells">
                <option value="" selected>Dir (N/A)</option>
								<option value="sem hipertrofias">Normal</option>
								<option value="hipertrofiadas">&uarr;Tamanho</option>
							</select>
						</div>
					</div>
					<div class="control is-expanded">
						<div class="select is-fullwidth">
							<select id="nose-e-shells">
