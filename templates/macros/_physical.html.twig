						<div class="select is-fullwidth">
							<select id="nose-sept">
                <option value="" selected>N/A</option>
								<option value="sem desvio aparente de septo nasal">&empty;Desvios</option>
								<option value="desvio leve de septo nasal para esquerda">Desvio &half;E</option>
								<option value="desvio moderado de septo nasal para esquerda">Desvio &frac34;E</option>
								<option value="desvio importante de septo nasal para esquerda">Desvio +E</option>
								<option value="desvio leve de septo nasal para direita">Desvio &half;D</option>
								<option value="desvio moderado de septo nasal para direita">Desvio &frac34;D</option>
								<option value="desvio importante de septo nasal para direita">Desvio +D</option>
							</select>
						</div>
					</div>
				</div>

        <div class="field">
          <div class="control is-expanded">
            <textarea class="textarea has-fixed-size" id="nose-other" placeholder="Descreva outras alterações otológicas..." rows="{{ app.user.getMiscRows | default(2) }}"></textarea>
          </div>
        </div>
			</div>
		</div>

		<hr>

		<div class="columns is-vcentered">
			<div class="column is-2">
				<div class="field">
					<label class="is-checkradio">
            <input type="checkbox" id="exam-hints" class="is-link">
						<span class="icon">
							<i class="mdi mdi-weather-hurricane mdi-24px"></i>
						</span>
					</label>
				</div>
			</div>

			<div class="column">
				<div class="field has-addons">
					<div class="control">
						<button class="button is-static" tabindex="-1">Head Impulse</button>
					</div>
					<div class="control is-expanded">
						<div class="select is-fullwidth">
							<select id="hints-hi" title="Avalição de Reflexo Vestibulo-Ocular, ou VOR em inglês.">
                <option value="" selected>N/A</option>
								<option value="sem latência bilateralmente" pattern="0">&empty;Latências</option>
								<option value="com latência à direita" pattern="1">Atraso à D</option>
								<option value="com latência à esquerda" pattern="1">Atraso à E</option>
								<option value="com latência a ambos os lados" pattern="1">Atraso bilateral</option>
							</select>
						</div>
					</div>
				</div>

				<div class="field has-addons">
					<div class="control">
						<button class="button is-static" tabindex="-1">Nistagmo</button>
					</div>
					<div class="control is-expanded">
						<div class="select is-fullwidth">
							<select id="hints-n">
                <option value="" selected>N/A</option>
								<option value="ausentes" pattern="0">Ausente</option>
								<option value="presentes, horizontal unilateral" pattern="-1">Horizontal Unilat.</option>
								<option value="presentes, torcional" pattern="-1">Torcional</option>
								<option value="presentes, horizontal COM MUDANÇA DE LATERALIDADE" pattern="1">Horizontal COM MUDANÇA DE LADO</option>
								<option value="presentes, VERTICAL para cima" pattern="1">Upbeat</option>
								<option value="presentes, VERTICAL para baixo" pattern="1">Downbeat</option>
							</select>
						</div>
					</div>
				</div>

				<div class="field has-addons">
					<div class="control">
						<button class="button is-static" tabindex="-1">Teste de&nbsp;<em>Skew</em>
						</button>
					</div>
					<div class="control is-expanded">
						<div class="select is-fullwidth">
							<select id="hints-ts">
                <option value="" selected>N/A</option>
								<option value="sem alterações" pattern="0">Normal</option>
								<option value="ALTERADO à direita" pattern="1">ALTERADO Dir</option>
                <option value="ALTERADO à esquerda" pattern="1">ALTERADO Esq</option>
                <option value="ALTERADO bilateralmente" pattern="1">ALTERADO Bilat</option>
							</select>
						</div>
					</div>
				</div>

        <p class="help">
          O processamento de padrão do HINTS está em
          <strong>estágio ALPHA</strong>, então faça
          <strong>dupla checagem do resultado</strong>
          antes de usá-lo!
        </p>
			</div>
		</div>
	</div>
</div>
{% endmacro %}

{##
  Includes a box div, containing a compile
  button, an output textarea and a copy button.
#}
{% macro output_box() %}
<div class="box">
  <h2 class="title is-4">Resultado</h2>

  <div class="field is-expanded">
    <div class="control is-expanded">
      <button id="output-compile" class="button is-primary is-fullwidth">
        <span class="icon-text">
          <span class="icon">
            <i class="mdi mdi-arrow-collapse"></i>
          </span>
          <span>Gerar</span>
        </span>
      </button>
    </div>
  </div>

  <div class="field is-expanded">
    <div class="control">
      <textarea id="output" class="textarea has-fixed-size" placeholder="Resultado..." rows="{{ app.getUser.getOutputRows | default(10) }}" readonly></textarea>
    </div>
  </div>

  <div class="field">
    <div class="control is-expanded">
      <button class="button is-fullwidth clipboard" data-clipboard-target="#output">
        <span class="icon-text">
          <span class="icon">
            <i class="mdi mdi-content-copy"></i>
          </span>
          <span>Copiar Resultado</span>
        </span>
      </button>
    </div>
  </div>
</div>
{% endmacro %}
